---
import BaseLayout from "../../layouts/BaseLayout.astro";
import wattsonSummary from "../../data/wattson-summary.json";
import tariffComparison from "../../data/wattson-tariff-comparison.json";

const formatKwh = (value: number) =>
  `${value.toLocaleString("en-GB", {
    minimumFractionDigits: 1,
    maximumFractionDigits: 1,
  })} kWh`;

const formatPercent = (value: number, fractionDigits = 2) =>
  `${value.toLocaleString("en-GB", {
    minimumFractionDigits: fractionDigits,
    maximumFractionDigits: fractionDigits,
  })}%`;

const formatCurrency = (value: number) =>
  value.toLocaleString("en-GB", {
    style: "currency",
    currency: "GBP",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });

const formatMonth = (value: string) => {
  const [year, month] = value.split("-").map(Number);
  return new Intl.DateTimeFormat("en-GB", {
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  }).format(new Date(Date.UTC(year, month - 1, 1)));
};

const formatSignedCurrency = (value: number) =>
  `${value > 0 ? "+" : ""}${formatCurrency(value)}`;

const lifetimeAvoidedImportValue =
  wattsonSummary.lifetime_avoided_import_value_gbp;
const lifetimeExportIncome = wattsonSummary.lifetime_export_income_gbp;
const lifetimeFinancialBenefit = wattsonSummary.lifetime_financial_benefit_gbp;
const lifetimeGeneration = wattsonSummary.lifetime_generation_kwh;
const lifetimeExport = wattsonSummary.lifetime_export_kwh;
const lifetimeSelfConsumed = wattsonSummary.lifetime_self_consumed_energy_kwh;
const selfConsumptionRatio = (lifetimeSelfConsumed / lifetimeGeneration) * 100;
const installationCost = 13000;
const recoveredAmount = lifetimeFinancialBenefit;
const remainingAmount = installationCost - recoveredAmount;
const nominalRecoveryPercentage = wattsonSummary.nominal_recovery_percentage;
const reportingMonthLabel = formatMonth(wattsonSummary.reporting_month);
const publicationMonthLabel = formatMonth(wattsonSummary.publication_month);
const dataQualityLabel = "validated";
const representativeComparison = tariffComparison.representative_12_month;
const tariffScenarioById = new Map(
  representativeComparison.scenarios.map((scenario) => [
    scenario.scenario_id,
    scenario,
  ]),
);
const monthlyScenarioGroups = new Map<
  string,
  typeof representativeComparison.monthly_scenarios
>();

for (const scenario of representativeComparison.monthly_scenarios) {
  const monthScenarios = monthlyScenarioGroups.get(scenario.month) ?? [];
  monthScenarios.push(scenario);
  monthlyScenarioGroups.set(scenario.month, monthScenarios);
}

const flowMax = Math.max(
  lifetimeGeneration,
  lifetimeSelfConsumed,
  lifetimeExport,
);

const flowWidth = (value: number) => Math.max(8, (value / flowMax) * 100);

const financialCards = [
  {
    label: "Lifetime financial benefit",
    value: formatCurrency(lifetimeFinancialBenefit),
  },
  {
    label: "Investment recovered",
    value: formatPercent(nominalRecoveryPercentage, 1),
  },
  {
    label: "Avoided import value",
    value: formatCurrency(lifetimeAvoidedImportValue),
  },
  {
    label: "Export income",
    value: formatCurrency(lifetimeExportIncome),
  },
  {
    label: "Simple payback",
    value: formatMonth(wattsonSummary.simple_payback_month),
  },
  {
    label: "Discounted payback",
    value: formatMonth(wattsonSummary.discounted_payback_month),
    note: "Using a 5% opportunity-cost rate",
  },
];

const energyCards = [
  {
    label: "Lifetime generation",
    value: formatKwh(lifetimeGeneration),
  },
  {
    label: "Lifetime self-consumed energy",
    value: formatKwh(lifetimeSelfConsumed),
  },
  {
    label: "Lifetime export",
    value: formatKwh(lifetimeExport),
  },
  {
    label: "Self-consumption percentage",
    value: formatPercent(selfConsumptionRatio, 1),
  },
];

const latestReportingCards = [
  {
    label: "Generation",
    value: formatKwh(wattsonSummary.monthly_generation_kwh),
  },
  {
    label: "Avoided import value",
    value: formatCurrency(wattsonSummary.monthly_avoided_import_value_gbp),
  },
  {
    label: "Export income",
    value: formatCurrency(wattsonSummary.monthly_export_income_gbp),
  },
  {
    label: "Total financial benefit",
    value: formatCurrency(wattsonSummary.monthly_total_benefit_gbp),
  },
];

const flowItems = [
  {
    label: "Generation",
    value: lifetimeGeneration,
  },
  {
    label: "Self-consumption",
    value: lifetimeSelfConsumed,
  },
  {
    label: "Export",
    value: lifetimeExport,
  },
];

const systemOverviewItems = [
  "16 x 400 W panels",
  "6.4 kWp installed capacity",
  "SolaX X1 Hybrid G4 inverter",
  "6 kWh SolaX battery",
  "Approximately due-south orientation",
  "Approximately 38\u00b0 roof pitch",
  "No significant shading",
  "Midlands, UK",
  "Octopus Flux tariff",
];

const measuredFlowScenarios = [
  {
    id: "octopus_flux",
    label: "Flux",
    detail: "Baseline measured-flow cost",
  },
  {
    id: "agile_import_agile_outgoing",
    label: "Agile + Agile Outgoing",
    detail: "Compatibility unconfirmed",
  },
  {
    id: "agile_import_flat_outgoing",
    label: "Agile + flat Outgoing",
    detail: "Compatibility unconfirmed",
  },
].map((scenario) => ({
  ...scenario,
  data: tariffScenarioById.get(scenario.id),
}));

const comparisonScenarioIds = [
  "agile_import_agile_outgoing",
  "agile_import_flat_outgoing",
];
const monthlyComparisonRows = [...monthlyScenarioGroups.entries()].map(
  ([month, scenarios]) => ({
    month,
    label: formatMonth(month).replace(" 20", " '"),
    values: comparisonScenarioIds.map((scenarioId) => {
      const scenario = scenarios.find(
        (item) => item.scenario_id === scenarioId,
      );
      return {
        scenarioId,
        value: scenario?.difference_vs_flux_gbp ?? null,
      };
    }),
  }),
);
const visibleMonthlyDifferences = monthlyComparisonRows
  .flatMap((row) => row.values.map((item) => item.value))
  .filter((value): value is number => value !== null);
const monthlyDifferenceMax = Math.max(
  1,
  ...visibleMonthlyDifferences.map((value) => Math.abs(value)),
);
---

<BaseLayout
  title="Wattson"
  description="Public Wattson dashboard for aggregated home energy intelligence metrics."
>
  <section class="section page-intro">
    <div class="container dashboard-hero">
      <div>
        <p class="eyebrow">Project Dashboard</p>
        <h1>Wattson</h1>
        <p class="project-subtitle">Home Energy Intelligence Platform</p>
        <p class="lede">
          Aggregated public metrics for a personal energy analytics platform
          combining validated solar, battery and household energy summaries.
        </p>
      </div>
      <div class="dashboard-actions">
        <span class="status-pill">In active development</span>
        <a class="button button-secondary" href="/projects/">Back to projects</a
        >
      </div>
    </div>
  </section>

  <section class="section section-muted" aria-labelledby="financial-heading">
    <div class="container section-stack">
      <div class="section-heading">
        <p class="eyebrow">Financial KPIs</p>
        <h2 id="financial-heading">Financial performance</h2>
        <p>
          Calculated from validated SolaX generation data and historical Octopus
          import and export tariffs. Updated monthly.
        </p>
      </div>
      <div class="kpi-grid kpi-grid-compact">
        {
          financialCards.map((card) => (
            <article class="kpi-card">
              <p>{card.label}</p>
              <strong>{card.value}</strong>
              {card.note && <small class="kpi-note">{card.note}</small>}
            </article>
          ))
        }
      </div>
      <article class="recovery-panel" aria-labelledby="recovery-heading">
        <div class="recovery-panel-header">
          <div>
            <h3 id="recovery-heading">Investment recovery</h3>
            <p>
              Against a {formatCurrency(installationCost)} installation cost.
            </p>
          </div>
          <strong>{formatPercent(nominalRecoveryPercentage, 1)}</strong>
        </div>
        <div
          class="recovery-track"
          role="img"
          aria-label={`Investment recovery ${formatPercent(nominalRecoveryPercentage, 1)}`}
        >
          <span style={`width: ${nominalRecoveryPercentage}%`}></span>
        </div>
        <dl class="recovery-stats">
          <div>
            <dt>Recovered amount</dt>
            <dd>{formatCurrency(recoveredAmount)}</dd>
          </div>
          <div>
            <dt>Remaining amount</dt>
            <dd>{formatCurrency(remainingAmount)}</dd>
          </div>
          <div>
            <dt>Progress</dt>
            <dd>{formatPercent(nominalRecoveryPercentage, 1)}</dd>
          </div>
        </dl>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="system-heading">
    <div class="container section-stack">
      <div class="section-heading">
        <p class="eyebrow">System Overview</p>
        <h2 id="system-heading">About the system</h2>
      </div>
      <ul class="system-list" aria-label="Wattson solar and battery system">
        {systemOverviewItems.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="energy-heading">
    <div class="container section-stack">
      <div class="section-heading">
        <p class="eyebrow">Energy KPIs</p>
        <h2 id="energy-heading">Energy performance</h2>
      </div>
      <div class="kpi-grid">
        {
          energyCards.map((card) => (
            <article class="kpi-card">
              <p>{card.label}</p>
              <strong>{card.value}</strong>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-muted" aria-labelledby="latest-heading">
    <div class="container section-stack">
      <div class="section-heading">
        <p class="eyebrow">Latest Reporting Month</p>
        <h2 id="latest-heading">{reportingMonthLabel}</h2>
        <p class="status-line">
          Reporting month: {reportingMonthLabel} · Data quality: {
            dataQualityLabel
          }
        </p>
      </div>
      <div class="kpi-grid">
        {
          latestReportingCards.map((card) => (
            <article class="kpi-card">
              <p>{card.label}</p>
              <strong>{card.value}</strong>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="tariff-heading">
    <div class="container section-stack">
      <div class="section-heading">
        <p class="eyebrow">Tariff What-if</p>
        <h2 id="tariff-heading">What if I changed tariff?</h2>
        <p>
          These comparisons reprice the energy my home actually imported and
          exported over a representative measured year. They do not assume that
          household, battery or EV behaviour changed.
        </p>
      </div>

      <div class="tariff-card-grid">
        {
          measuredFlowScenarios.map((scenario) => (
            <article class="tariff-card">
              <div>
                <p>{scenario.label}</p>
                <strong>
                  {scenario.data
                    ? formatCurrency(scenario.data.net_cost_gbp)
                    : "Unavailable"}
                </strong>
              </div>
              <span
                class={
                  scenario.id === "octopus_flux"
                    ? "tariff-badge tariff-badge-current"
                    : "tariff-badge"
                }
              >
                {scenario.detail}
              </span>
              {scenario.id !== "octopus_flux" &&
              scenario.data?.difference_vs_flux_gbp ? (
                <small>
                  {formatCurrency(
                    Math.abs(scenario.data.difference_vs_flux_gbp),
                  )}{" "}
                  lower than Flux
                </small>
              ) : null}
            </article>
          ))
        }
      </div>

      <article class="seasonality-panel" aria-labelledby="seasonality-heading">
        <div class="seasonality-header">
          <div>
            <h3 id="seasonality-heading">Monthly seasonality versus Flux</h3>
            <p>
              Positive means Flux was cheaper; negative means the alternative
              was cheaper.
            </p>
          </div>
          <div class="seasonality-legend" aria-label="Tariff comparison legend">
            <span
              ><i class="legend-mark legend-agile"></i>Agile + Agile Outgoing</span
            >
            <span
              ><i class="legend-mark legend-flat"></i>Agile + flat Outgoing</span
            >
          </div>
        </div>

        <div class="seasonality-chart" aria-labelledby="seasonality-heading">
          {
            monthlyComparisonRows.map((row) => (
              <div class="seasonality-month">
                <span class="seasonality-label">{row.label}</span>
                <div class="seasonality-bars">
                  <span class="seasonality-zero" aria-hidden="true" />
                  {row.values.map((item) => (
                    <span
                      class={`seasonality-bar ${
                        item.scenarioId === "agile_import_agile_outgoing"
                          ? "seasonality-bar-agile"
                          : "seasonality-bar-flat"
                      } ${item.value && item.value < 0 ? "is-negative" : "is-positive"}`}
                      style={`--bar-size: ${
                        item.value === null
                          ? 0
                          : (Math.abs(item.value) / monthlyDifferenceMax) * 50
                      }%;`}
                      title={
                        item.value === null
                          ? "Insufficient coverage"
                          : `${row.label}: ${formatSignedCurrency(item.value)}`
                      }
                    >
                      <span class="sr-only">
                        {item.value === null
                          ? `${row.label}: insufficient coverage`
                          : `${row.label}: ${formatSignedCurrency(item.value)}`}
                      </span>
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </article>

      <p class="experimental-note">
        Tariff-aware battery optimisation is simulated and was not actually
        carried out.
      </p>
    </div>
  </section>

  <section class="section section-muted" aria-labelledby="flow-heading">
    <div class="container energy-flow-layout">
      <div class="section-heading">
        <p class="eyebrow">Energy Flow</p>
        <h2 id="flow-heading">Lifetime flow overview</h2>
        <p>
          A simple proportional view of generation, self-consumption, export,
          and public financial-reporting energy totals.
        </p>
      </div>
      <div class="flow-panel" role="img" aria-labelledby="flow-heading">
        {
          flowItems.map((item) => (
            <div class="flow-row">
              <div class="flow-row-header">
                <span>{item.label}</span>
                <strong>{formatKwh(item.value)}</strong>
              </div>
              <div class="flow-track" aria-hidden="true">
                <span style={`width: ${flowWidth(item.value)}%`} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="methodology-heading">
    <div class="container info-grid">
      <article class="content-panel">
        <h2 id="methodology-heading">Methodology</h2>
        <p>
          Energy totals come from validated SolaX historical reports. Financial
          values use tariff-covered Octopus unit-rate calculations.
        </p>
        <p>
          The latest published snapshot covers reporting month
          {reportingMonthLabel}, published in {publicationMonthLabel}.
        </p>
        <p>
          Calculations exclude standing charges, system financing, maintenance,
          degradation and opportunity cost.
        </p>
        <p>
          Phase 1 runs from SolaX data through validation and canonical metrics,
          then into Octopus tariffs and financial modelling, privacy-safe
          monthly summaries and this public website. Detailed live weather,
          household flows and forecasts remain private.
        </p>
      </article>

      <article class="content-panel">
        <h2>Data Coverage and Quality</h2>
        <dl class="definition-list">
          <div>
            <dt>Coverage dates</dt>
            <dd>
              Reporting month {reportingMonthLabel}; publication month
              {publicationMonthLabel}
            </dd>
          </div>
          <div>
            <dt>Data quality</dt>
            <dd>{dataQualityLabel}</dd>
          </div>
          <div>
            <dt>Nominal recovery</dt>
            <dd>{formatPercent(nominalRecoveryPercentage, 1)}</dd>
          </div>
          <div>
            <dt>Discounted recovery</dt>
            <dd>
              {formatPercent(wattsonSummary.discounted_recovery_percentage)}
            </dd>
          </div>
          <div>
            <dt>Financial status</dt>
            <dd>Validated monthly financials.</dd>
          </div>
        </dl>
      </article>
    </div>
  </section>
</BaseLayout>
