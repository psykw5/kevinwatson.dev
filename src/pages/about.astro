---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About"
  description="A brief professional profile for Kevin Watson, Data Engineer."
>
  <section class="section page-intro">
    <div class="container narrow">
      <p class="eyebrow">About</p>
      <h1>Engineering useful data systems with care and clarity.</h1>
      <p class="lede">
        I am a data engineer interested in the practical systems that turn raw
        data into dependable insight and better decisions.
      </p>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container content-panel">
      <h2>Interests</h2>
      <p>
        My work and learning interests include data engineering, analytics
        applications, machine learning, visualisation, automation and
        optimisation.
      </p>
      <p>
        This site is a focused portfolio for publishing selected engineering
        projects as they become ready to share.
      </p>
    </div>
  </section>
</BaseLayout>
