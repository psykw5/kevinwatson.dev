---
interface Props {
  title: string;
  subtitle?: string;
  status?: string;
  description: string;
  technologies?: string[];
  href?: string;
  linkLabel?: string;
  placeholder?: boolean;
}

const {
  title,
  subtitle,
  status,
  description,
  technologies = [],
  href,
  linkLabel = "View project",
  placeholder = false,
} = Astro.props;
---

<article
  class:list={["project-card", { "project-card-placeholder": placeholder }]}
>
  <div class="project-card-header">
    <div>
      <h3>{title}</h3>
      {subtitle && <p class="project-subtitle">{subtitle}</p>}
    </div>
    {status && <span class="status-pill">{status}</span>}
  </div>
  <p>{description}</p>
  {
    technologies.length > 0 && (
      <ul class="tech-list" aria-label={`${title} technologies`}>
        {technologies.map((technology) => (
          <li>{technology}</li>
        ))}
      </ul>
    )
  }
  {
    href && (
      <a class="project-link" href={href}>
        {linkLabel}
      </a>
    )
  }
</article>
